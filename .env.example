# SSH MCP Server Configuration
# Copy this file to .env and customize

# Path to your SSH servers YAML configuration
# Can be absolute or relative to the project root
SSH_SERVERS_FILE=ssh_servers.yaml

# Default SSH command timeout in seconds
SSH_TIMEOUT=30

# Maximum connection retries
SSH_MAX_RETRIES=3

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# MCP Server name and version (shown in MCP client)
MCP_SERVER_NAME=ssh-mcp
MCP_SERVER_VERSION=0.1.0

# HTTP mode settings (for ssh-mcp-web)
MCP_PORT=8086
MCP_SECRET_PATH=/mcp
